{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"],
        "excludes": [
            "src/Log/LogLevel.php",
            "src/Support/HookPoint.php"
        ]
    },
    "logs": {
        "text": "infection-log.txt"
    },
    "minMsi": 80,
    "minCoveredMsi": 85,
    "testFramework": "phpunit"
}

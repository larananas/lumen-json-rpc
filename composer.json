{
  "name": "larananas/lumen-json-rpc",
  "description": "Framework-free JSON-RPC 2.0 server library for modern PHP.",
  "type": "library",
  "license": "LGPL-3.0-or-later",
  "keywords": [
    "json-rpc",
    "rpc",
    "json",
    "server",
    "php",
    "api",
    "lumen"
  ],
  "require": {
    "php": ">=8.2",
    "ext-json": "*"
  },
  "require-dev": {
    "infection/infection": "^0.32",
    "justinrainbow/json-schema": "^5.3 || ^6.0",
    "phpstan/phpstan": "2.1.51",
    "phpunit/phpunit": "^10.5"
  },
  "suggest": {
    "ext-zlib": "Optional. Required for gzip request/response compression support.",
    "firebase/php-jwt": "Optional. The library includes a built-in HMAC JWT decoder. Install this for broader algorithm support or advanced token handling."
  },
  "autoload": {
    "psr-4": {
      "Lumen\\JsonRpc\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lumen\\JsonRpc\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/generate-docs.php"
  ],
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "check:coverage-driver": "@php bin/check-coverage-driver.php",
    "test:coverage": [
      "@check:coverage-driver",
      "@php vendor/bin/phpunit --coverage-text --coverage-clover=coverage.xml"
    ],
    "stan": "@php vendor/bin/phpstan analyse --memory-limit=512M",
    "mutate": [
      "@check:coverage-driver",
      "@php vendor/bin/infection --threads=max --min-msi=80 --min-covered-msi=85"
    ],
    "lint": "@php bin/lint-syntax.php",
    "verify:package": "@php bin/verify-package.php",
    "check:coverage": "@php bin/check-coverage.php",
    "package:build": "git archive HEAD --output=dist.tar && echo \"Package built: dist.tar\"",
    "package:verify": [
      "@verify:package",
      "@package:build"
    ],
    "docs:clean": "@php -r \"array_map('unlink', glob('docs-site/**/*', GLOB_BRACE)); array_map('rmdir', glob('docs-site/*', GLOB_ONLYDIR));\"",
    "check": [
      "@stan",
      "@test"
    ],
    "qa": [
      "@php composer validate --strict --no-check-version",
      "@php composer audit --abandoned=report",
      "@verify:package",
      "@lint",
      "@stan",
      "@test"
    ],
    "qa:max": [
      "@php composer validate --strict --no-check-version",
      "@php composer audit --abandoned=report",
      "@verify:package",
      "@lint",
      "@stan",
      "@test:coverage",
      "@check:coverage",
      "@mutate"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

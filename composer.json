{
  "name": "larananas/lumen-json-rpc",
  "description": "Illuminate your PHP backend with JSON-RPC 2.0 clarity.",
  "type": "library",
  "license": "LGPL-3.0-or-later",
  "keywords": [
    "json-rpc",
    "rpc",
    "json",
    "server",
    "php",
    "api",
    "lumen"
  ],
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-zlib": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "suggest": {
    "firebase/php-jwt": "Optional. The library includes a built-in HMAC JWT decoder. Install this for broader algorithm support or advanced token handling."
  },
  "autoload": {
    "psr-4": {
      "Lumen\\JsonRpc\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lumen\\JsonRpc\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/generate-docs.php"
  ],
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
